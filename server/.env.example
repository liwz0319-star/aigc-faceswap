# Xais AI / Nano_Banana_Pro API 配置（relay 模式）
LAS_API_KEY=your_api_key_here
LAS_BASE_URL=https://sg2c.dchai.cn/v1
SEEDREAM_MODEL=Nano_Banana_Pro_2K_0
SEEDREAM_MODE=relay

# Seedream 官方 API（native 模式，可选）
SEEDREAM_NATIVE_API_URL=https://api.seedream.com/v1/images/generations
SEEDREAM_NATIVE_API_KEY=your_native_api_key_here
SEEDREAM_NATIVE_MODEL=doubao-seedream-4-5-251128

# 服务配置
PORT=3001
NODE_ENV=production
DEFAULT_USER_MODE=child

# API 认证密钥（留空则不校验；生产环境建议开启）
SERVER_API_KEY=

# BullMQ / Redis 队列配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
TASK_RETENTION_SECONDS=7200

# H5 回调地址
H5_CALLBACK_URL=
