# 火山引擎 LAS API 配置
LAS_API_KEY=your_las_api_key_here
LAS_BASE_URL=https://operator.las.cn-beijing.volces.com/api/v1
SEEDREAM_MODEL=doubao-seedream-4-5-251128

# 服务配置
PORT=3000
NODE_ENV=development
DEFAULT_USER_MODE=child
ENABLE_EMBEDDED_WORKER=true

# API 认证密钥（留空则不校验；生产环境建议开启）
SERVER_API_KEY=your_server_api_key_here

# BullMQ / Redis 队列配置
MAX_CONCURRENT=3
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_URL=redis://default:password@127.0.0.1:6379/0
TASK_RETENTION_SECONDS=7200
BULLMQ_JOB_ATTEMPTS=1
BULLMQ_JOB_BACKOFF_MS=0

# H5 后端提供的返回结果接口地址（按 H5 技术对接文档配置）
H5_CALLBACK_URL=

# CDN/存储配置（结果图片上传，可选）
CDN_UPLOAD_URL=
CDN_API_KEY=
